# Bungie credentials — single repo-root .env for local dev.
#
# Bungie allows ONE redirect URL per app, so you need TWO Bungie apps:
#   • dev app  → credentials go here (localhost redirect)
#   • prod app → credentials go in Vercel (production redirect)
#
# Full walkthrough: docs/bungie-setup.md

# --- Dev Bungie app (https://localhost:4111/api/auth/callback) ---
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=
# Auto-generated by `pnpm setup:bungie` if left blank:
SESSION_SECRET=

# --- Upstash Redis — weapon popularity counters (optional locally) ---
# See docs/popularity-setup.md. Opt in explicitly; unset on Vercel until you want "Popular lately" live.
# POPULAR_WEAPONS_ENABLED=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Dev-only: skip Redis popularity reads/writes when sharing a prod Upstash DB locally (never set on Vercel).
# POPULAR_WEAPONS_MOCK=true

# --- Microsoft Clarity — session recordings & heatmaps (production only on Vercel) ---
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
