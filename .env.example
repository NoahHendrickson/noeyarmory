# Bungie.net API key — required only to (re)generate the weapon index.
#
# 1. Sign in at https://www.bungie.net/en/Application and "Create New App".
# 2. OAuth Client Type: "Not Applicable" (manifest reads need no user login).
# 3. Copy the "API Key" and paste it below.
#
# Used at build/prep time by `pnpm --filter @repo/destiny generate`.
# Never bundled into the client.
BUNGIE_API_KEY=
