# Bungie.net API key — required only to (re)generate the weapon index.
#
# 1. Sign in at https://www.bungie.net/en/Application and "Create New App".
# 2. OAuth Client Type: "Not Applicable" (manifest reads need no user login).
# 3. Copy the "API Key" and paste it below.
#
# Used at build/prep time by `pnpm --filter @repo/destiny generate`.
# Never bundled into the client.
BUNGIE_API_KEY=

# --- Vault search (OAuth) — only needed for the "My Vault" feature ---
# In your Bungie app, set OAuth Client Type = "Confidential" to get these,
# and register the redirect URL below.
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=
BUNGIE_OAUTH_REDIRECT=http://localhost:3000/api/auth/callback
# 32+ char secret used to encrypt the session cookie (generate your own).
SESSION_SECRET=
