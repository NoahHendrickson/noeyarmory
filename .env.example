# Bungie credentials — single repo-root .env for local dev.
#
# Bungie allows ONE redirect URL per app, so you need TWO Bungie apps:
#   • dev app  → credentials go here (localhost redirect)
#   • prod app → credentials go in Vercel (production redirect)
#
# Full walkthrough: docs/bungie-setup.md

# --- Dev Bungie app (https://localhost:4111/api/auth/callback) ---
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=
# Auto-generated by `pnpm setup:bungie` if left blank:
SESSION_SECRET=

# --- In-app feedback → GitHub Issues (required for feedback) ---
# Fine-grained PAT with Issues read/write on GITHUB_REPO. See docs/feedback-setup.md.
GITHUB_TOKEN=
GITHUB_REPO=noahhendrickson/noeyarmory
# GITHUB_FEEDBACK_LABEL_BUG=bug
# GITHUB_FEEDBACK_LABEL_FEATURE=enhancement

# --- Upstash Redis — weapon popularity counters (optional locally) ---
# See docs/popularity-setup.md. Required in production for "Popular lately" on the home screen.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Dev-only: fake popular weapons on the home screen without writing to Redis (never set on Vercel).
# POPULAR_WEAPONS_MOCK=true

# --- Microsoft Clarity — session recordings & heatmaps (production only on Vercel) ---
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
